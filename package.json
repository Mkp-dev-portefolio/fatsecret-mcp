{
  "name": "fatsecret-mcp",
  "version": "1.0.0",
  "description": "MCP server for the FatSecret nutrition and food-logging API — search foods, log meals, and analyse nutrition with any LLM that supports Model Context Protocol.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "fatsecret",
    "nutrition",
    "food",
    "calories",
    "diet",
    "health",
    "claude",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fatsecret-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/fatsecret-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/fatsecret-mcp/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/fatsecret-mcp#readme"
}
