# ─── FatSecret API Credentials ────────────────────────────────────────────────
# Register at https://platform.fatsecret.com to obtain these.

# Required — OAuth 2.0 client credentials (for food search, food lookup, recipes)
FATSECRET_CLIENT_ID=your_client_id_here
FATSECRET_CLIENT_SECRET=your_client_secret_here

# Optional — OAuth 1.0 user tokens (required for diary & monthly stats tools)
# To obtain: complete the OAuth 1.0 three-legged flow for your FatSecret account.
# See README.md → "Obtaining User Tokens" for step-by-step instructions.
FATSECRET_ACCESS_TOKEN=your_oauth1_access_token_here
FATSECRET_ACCESS_TOKEN_SECRET=your_oauth1_access_token_secret_here
